# =================================================================
# PlatformLucasArrial — Environment Variables Template
# Copy this to .env (backend) and frontend/.env.local (frontend)
# NEVER commit the actual .env or .env.local files
# =================================================================

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO
NEXT_PUBLIC_APP_NAME=PlatformLucasArrial
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# --- Supabase (NEW project — create at supabase.com for LucasArrial) ---
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_ACCESS_TOKEN=

# --- Auth: Google OAuth (NEW credentials at console.cloud.google.com) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Auth: Github OAuth (optional) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Anti-bot: Cloudflare Turnstile ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Email transactional: Resend ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO=

# --- AI providers (backend only, used for voice cloning / aux features) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
HUGGINGFACE_TOKEN=

# --- RunPod (voice cloning workers) ---
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# --- Hetzner (deploy target) ---
HETZNER_API_TOKEN=

# --- Sentry (erro tracking — opcional em dev, obrigatório em prod) ---
# Pegar em https://sentry.io após criar conta + project
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token só pra build (source maps upload) — gerar em Sentry → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=

# --- Logging ---
# Override do path padrão (../logs/FrontendServer.log)
# LOG_DIR=
# LOG_FILE_NAME=

# --- Misc ---
API_TEST_MODE=false
